# ===========================================
# DEEE TODO - Variables de Entorno
# Copia este archivo como .env.local para desarrollo
# ===========================================

# NextAuth (OBLIGATORIO)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=genera-un-secret-seguro-aqui-con-openssl-rand-base64-32

# Shopify Storefront API (Opcional - usa productos demo si no se configura)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Google Sheets (Opcional - los formularios funcionan sin esto)
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=

# EmailJS (Para enviar pedidos del personalizador por email - opción cliente)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_deeetodo
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_pedido
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# SMTP / Nodemailer (Para enviar pedidos con archivos adjuntos - opción servidor)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password
ORDER_EMAIL_TO=info@deeetodo.com
